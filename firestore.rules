rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    // ─── Public collections (read-only for everyone) ─────────────────────
    // Services, Projects, Equipment pages — data shown to all visitors
    match /services/{doc} {
      allow read: if true;
      allow write: if isAuth();
    }

    match /projects/{doc} {
      allow read: if true;
      allow write: if isAuth();
    }

    match /equipment/{doc} {
      allow read: if true;
      allow write: if isAuth();
    }

    // ─── Contact form — anyone can submit, only admin can read ───────────
    match /contacts/{doc} {
      allow create: if true;            // public form submission
      allow read, update, delete: if isAuth();
    }

    // ─── Admin-only collections (requires login) ─────────────────────────
    match /workers/{doc} {
      allow read, write: if isAuth();
    }

    match /payroll/{doc} {
      allow read, write: if isAuth();
    }

    match /accounting/{doc} {
      allow read, write: if isAuth();
    }

    match /tracking/{doc} {
      allow read, write: if isAuth();
    }

    match /users/{userId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
    }

    // ─── Deny everything else by default ────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

