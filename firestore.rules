rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() && exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
    }

    // ─── Admins Collection (Publicly readable to check status, writable by admins) ─
    match /admins/{email} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ─── Public collections (read-only for everyone) ─────────────────────
    match /services/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /projects/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /equipment/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /machines/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /materials/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── Contact form — anyone can submit, only admin can read ───────────
    match /contacts/{doc} {
      allow create: if true;            
      allow read, update, delete: if isAdmin();
    }

    // ─── Admin-only collections (requires login as admin) ────────────────
    match /workers/{doc} {
      allow read, write: if isAdmin();
    }
    
    match /employees/{doc} {
      allow read, write: if isAdmin();
    }

    match /payroll/{doc} {
      allow read, write: if isAdmin();
    }

    match /accounting/{doc} {
      allow read, write: if isAdmin();
    }

    match /tracking/{doc} {
      allow read, write: if isAdmin();
    }

    match /users/{userId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
    }

    // ─── Deny everything else by default ────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

